[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	email = xian.z512@gmail.com
	name = Xian Zhang
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFV3YS3s5RPAeSJV+JW7gGF/oKmHXJAsCK9B+H+CUlJw
[url "git@github.com:"]
	insteadOf = https://github.com/
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
