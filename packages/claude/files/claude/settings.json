{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "skillOverrides": {
    "claude-api": "off"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '~/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/statusline.js\""
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/subagent-statusline.js\""
  },
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": ""
  },
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
