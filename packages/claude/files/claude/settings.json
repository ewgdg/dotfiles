{
  "permissions": {
    "allow": [],
    "deny": [
      "Skill(claude-api)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/xian/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/statusline.js\""
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/subagent-statusline.js\""
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true
}
