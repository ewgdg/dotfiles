address=127.0.0.1
port=5900

# SSH tunnels are the access boundary; services bind only to localhost.
enable_auth=false

use_relative_paths=true
private_key_file=tls_key.pem
certificate_file=tls_cert.pem
rsa_private_key_file=rsa_key.pem

# Needed for macOS Screen Sharing / legacy VNC compatibility.
#relax_encryption=true
#allow_broken_crypto=true
