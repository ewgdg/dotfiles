{
  "$schema": "https://schema.linearmouse.app/0.11.2",
  "schemes": [
    {
      "if": {
        "device": {
          "category": "mouse"
        }
      },
      "buttons": {
        "universalBackForward": true
      },
      "pointer": {
        "acceleration": 1,
        "disableAcceleration": true,
        "speed": 0.06896551724137928
      },
      "scrolling": {
        "acceleration": {
          "vertical": 1
        },
        "distance": {
          "horizontal": "auto",
          "vertical": "66.9px"
        },
        "modifiers": {
          "vertical": {
            "command": {
              "scale": 10,
              "type": "changeSpeed"
            },
            "control": {
              "type": "auto"
            }
          }
        },
        "reverse": {
          "horizontal": false,
          "vertical": true
        },
        "smoothed": {
          "vertical": {
            "enabled": false
          }
        },
        "speed": {
          "vertical": 0
        }
      }
    },
    {
      "if": {
        "device": {
          "category": "trackpad"
        }
      },
      "scrolling": {
        "acceleration": {
          "vertical": 1
        },
        "distance": {
          "vertical": "auto"
        },
        "speed": {
          "vertical": 0
        }
      }
    }
  ]
}
