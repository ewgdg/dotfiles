# os: {{ os }}

{% include 'env.core.sh' %}
{% if os == "darwin" %}
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{% endif %}
{% if os == "darwin" %}
export SUDO_ASKPASS="$HOME/bin/askpass-macos"
{% elif os == "linux" %}
export SUDO_ASKPASS="$HOME/bin/askpass-gui"
{% endif %}