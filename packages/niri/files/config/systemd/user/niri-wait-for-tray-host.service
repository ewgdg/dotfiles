[Unit]
Description=Wait for tray host readiness in Niri
After=niri.service
BindsTo=niri.service
PartOf=niri.service
Before=xdg-desktop-autostart.target
Before=graphical-session.target

[Service]
Type=oneshot
TimeoutStartSec=20
ExecStart=/usr/local/bin/wait-for-status-notifier-host
RemainAfterExit=yes

[Install]
WantedBy=niri.service
