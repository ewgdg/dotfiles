# Session-wide environment for Niri.
# Imported by the niri.service drop-in before `niri --session`, so niri,
# niri-spawned apps, user services, and D-Bus activation share these static vars.

# ELECTRON_OZONE_PLATFORM_HINT=auto
# QT_QPA_PLATFORM=wayland
# QT_QPA_PLATFORMTHEME=kde
# QT_QPA_PLATFORMTHEME=xdgdesktopportal
# QT_QPA_PLATFORMTHEME=qt6ct
QT_QPA_PLATFORMTHEME=gtk3
# Disable DrKonqi in the Niri session. KDE tools honor KDE_DEBUG and skip
# launching the crash reporter, which avoids the observed DrKonqi crash loop.
# KDE_DEBUG=1
# Point KDE menu lookups at /etc/xdg/menus/plasma-applications.menu so KDE
# components do not fall back to the missing plain applications.menu file.
# required for dolphin to find default application to open a file?
# XDG_MENU_PREFIX=plasma-
QS_ICON_THEME=Papirus-Dark

# GTK_IM_MODULE=fcitx
QT_IM_MODULE=fcitx
QT_IM_MODULES='wayland;fcitx;ibus'
XMODIFIERS='@im=fcitx'
SDL_IM_MODULE=fcitx
