{
  "rules": [
    {
      "name": "hide-null-window",
      "event": "window-opened",
      "match": {
        "current": {
          "app_id": {
            "equals": null
          },
          "title": {
            "equals": null
          }
        }
      },
      "action": {
        "type": "hide",
        "target": "current",
        "workspace": "stash"
      }
    },
    {
      "name": "close-floating-goldendict-on-focus-loss",
      "event": "focus-changed",
      "match": {
        "previous": {
          "app_id": {
            "regex": "goldendict",
            "ignore_case": true
          },
          "is_floating": true
        }
      },
      "action": {
        "type": "close-window",
        "target": "previous"
      }
    }
  ]
}
