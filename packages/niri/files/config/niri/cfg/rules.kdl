// https://github.com/niri-wm/niri/wiki/Configuration:-Window-Rules

// You can find the title and the app ID of a window by running niri msg pick-window

window-rule {
    draw-border-with-background false
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    // Keep utility windows floating.
    // Includes 1Password (and Quick Access) and GoldenDict.
    match app-id=r#"(?i)^1password(-quickaccess)?$"#
    // Open DMS windows as floating by default
    // match app-id=r#"org.quickshell$"#
    open-floating true
    focus-ring {
        off
    }
    border {
        off
    }
}

window-rule {
    match app-id=r#"(?i)goldendict"#
    open-floating true
    default-window-height { fixed 600; }
    default-column-width { fixed 800; }
    max-height 600
    max-width 800
}

// window-rule {
//     // Focus the keyring unlock prompt when it appears.
//     match app-id=r#"(?i)^gcr-prompter$"#
//     match title=r#"(?i)unlock keyring"#
//     match app-id=r#"org.kde.ksecretd"#
//     // open-floating true
//     open-focused true
// }

window-rule {
    // Steam notification windows: float and position at bottom-right.
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

window-rule {
    // Open Steam's main window on the dedicated game workspace.
    match app-id="steam"
    match app-id="lutris"
    open-on-workspace "games"
}

// Games
window-rule {
    match app-id=r#"^steam_app_"#
    match app-id=r#"\.exe$"#
    open-floating true
}

window-rule {
  match title=r#"(?i)^Battle.net$"#
  open-on-workspace "games"
  open-floating false
}

window-rule {
  // wine legacy tray icon
  match app-id=r#"^explorer.exe$"#
  open-on-workspace "stash"
  open-floating false
}

window-rule {
    match at-startup=true title=r#"(?i)^Google AI Studio\b"#
    open-focused false
}

window-rule {
    match title=r#"(?i)^ChatGPT\b"#
    match title=r#"(?i)^Google AI Studio\b"#
    open-on-workspace "AI"
}

window-rule {
    // Keep note-taking apps on the dedicated notes workspace.
    match app-id=r#"(?i)^obsidian$"#
    match title=r#"(?i)\bmemos\b"#
    open-on-workspace "notes"
}

window-rule {
    // Route the autostarted journal tail terminal to the logs workspace.
    match title="logs-journalctl"
    open-on-workspace "logs"
}

// maximized apps
window-rule {
    match app-id=r#"(?i)^code$"#
    match app-id=r#"(?i)^obsidian$"#
    match app-id=r#"(?i)^google-chrome$"#
    open-maximized true
}

window-rule {
    // Fcitx5 indicator/candidate windows: float without focus ring/border.
    // Fcitx5 window should not steal focus.
    match app-id=r#"(?i)^fcitx$"# title="^Fcitx5 Input Window$"
    open-floating true
    open-focused false
    clip-to-geometry false
    tiled-state true
    default-floating-position x=0 y=0 relative-to="bottom-right"
    focus-ring {
        off
    }
    border {
        off   
    }
    shadow {
        off
    }
}

window-rule {
    match is-active=false
    opacity 0.9
    // we want a colored background for the translucent window
    draw-border-with-background true
}

window-rule {
    match is-floating=true
    focus-ring {
        off
    }
    border {
        on
        // active-color "transparent"
    }
}

// Indicate screencasted windows with red colors.
window-rule {
    match is-window-cast-target=true

    focus-ring {
        active-color "#f38ba8"
        inactive-color "#7d0d2d"
    }

    border {
        inactive-color "#7d0d2d"
    }

    shadow {
        color "#7d0d2d70"
    }

    tab-indicator {
        active-color "#f38ba8"
        inactive-color "#7d0d2d"
    }
}

layer-rule {
    // dms: Tell niri to place the wallpaper on the overview.
    match namespace="^quickshell$"
    
    match namespace="^noctalia-wallpaper"

    place-within-backdrop true
}
