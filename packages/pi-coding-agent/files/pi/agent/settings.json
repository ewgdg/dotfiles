{
	"packages": [
		"npm:pi-vim",
		"npm:pi-mcporter",
		"npm:pi-herdr-subagents",
		"npm:@howaboua/pi-codex-conversion",
		"npm:@narumitw/pi-btw",
		"git:github.com/ewgdg/pi-multicodex"
	],
	"enabledModels": [
		"deepseek/deepseek-v4-flash",
		"deepseek/deepseek-v4-pro",
		"openai-codex/gpt-5.6-luna",
		"openai-codex/gpt-5.6-sol",
		"openai-codex/gpt-5.6-terra"
	],
	"theme": "dark",
	"pi-openai-controls": {
		"web_search": {
			"mode": "live"
		},
		"service_tier": {
			"default": "auto"
		}
	},
	"compaction": {
		"enabled": true,
		"reserveTokens": 22000
	},
	"treeFilterMode": "default",
	"enableInstallTelemetry": false,
	"terminal": {
		"showTerminalProgress": true
	},
	"enableSkillCommands": true,
	"pi-select-patch": {
		"anchorMode": "tolerant"
	},
	"extensions": [
		"-extensions/pi-openai-controls/index.ts",
		"+extensions/pi-openrouter-controls/index.ts"
	]
}
