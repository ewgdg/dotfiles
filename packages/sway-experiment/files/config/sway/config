# Minimal Sway config for trying Sway while keeping main Niri/Mango habits.
# Docs: man 5 sway, man 5 sway-input.
#
# Intentional simplifications:
# - Sway workspaces replace Niri named workspaces / Mango tags.
# - Sway scratchpad is closest native replacement for Niri pinned/stash helpers.
# - No Niri helper scripts are reimplemented here.
# - Missing native equivalents stay as TODO comments.

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $launcher qs -c noctalia-shell ipc call launcher toggle
set $launcher_windows qs -c noctalia-shell ipc call launcher windows

# Workspace map:
# 1 main | 2 stash | 3 notes | 4 AI | 5 logs | 6 games | 7-9 spare
set $ws1 1
set $ws2 2
set $ws3 3
set $ws4 4
set $ws5 5
set $ws6 6
set $ws7 7
set $ws8 8
set $ws9 9

### Session startup
# Runtime display vars only exist after Sway starts; session.env vars are imported by start-sway.
# Keep env import and service start in one shell so sway-shell cannot race the import.
exec sh -lc 'dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY SWAYSOCK; systemctl --user start sway-shell.service'

# Native autostart only.
exec launch-desktop-app memos '^chrome-.*-Default[.]desktop$'
exec obsidian
exec launch-desktop-app ChatGPT '^chrome-.*-Default[.]desktop$'
exec launch-desktop-app 'Google AI Studio' '^chrome-.*-Default[.]desktop$'
exec sh -lc 'exec "${TERMINAL:-alacritty}" --title logs-journalctl -e journalctl -f -n 20'

### Output / look
output * bg #000000 solid_color
font pango:Cascadia Code NF 10
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart
smart_gaps on
gaps inner 5
gaps outer 5
focus_follows_mouse no
mouse_warping none
workspace_layout default
xwayland enable

client.focused          #ffc87f #ffc87f #000000 #ffc87f #ffc87f
client.focused_inactive #505050 #505050 #ffffff #505050 #505050
client.unfocused        #282828 #282828 #bdae93 #282828 #282828
client.urgent           #9b0000 #9b0000 #ffffff #9b0000 #9b0000

### Input
input type:keyboard {
    xkb_layout us
    repeat_delay 600
    repeat_rate 25
}

input type:touchpad {
    tap enabled
    dwt enabled
    natural_scroll enabled
}

input type:pointer {
    # Match Niri: flat libinput profile disables pointer acceleration.
    accel_profile flat
    pointer_accel 0
}

### App placement. Keep only simple native rules.
assign [app_id="^steam$"] $ws6
assign [app_id="^lutris$"] $ws6
assign [title="^Battle\\.net$"] $ws6
assign [app_id="^explorer\\.exe$"] $ws2
assign [app_id="^obsidian$"] $ws3
assign [title="^Memos$"] $ws3
assign [title="^ChatGPT$"] $ws4
assign [title="^Google AI Studio$"] $ws4
assign [title="^logs-journalctl$"] $ws5

for_window [app_id="^1password(-quickaccess)?$"] floating enable
for_window [app_id="(?i)goldendict"] floating enable, resize set 800 600
# TODO: add maximize-on-open rules if you want stronger Sway-native placement.
# TODO: add Fcitx / Steam toast special cases after observing Sway app_id/title values.

### Key bindings
# Keep Niri/Mango muscle memory where Sway has close native actions.
bindsym $mod+Return exec $term
bindsym $mod+space exec $launcher
bindsym $mod+Shift+space exec $launcher_windows
bindsym $mod+b exec google-chrome-stable
bindsym $mod+d exec goldendict
bindsym $mod+Ctrl+d exec goldendict-search
bindsym $mod+e exec nautilus --new-window
bindsym $mod+Ctrl+Shift+space exec 1password --quick-access

bindsym $mod+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Ctrl+Shift+Delete exec swaynag -t warning -m 'Exit Sway?' -B 'Yes, exit Sway' 'swaymsg exit'

# Noctalia actions.
bindsym $mod+Ctrl+Shift+l exec qs -c noctalia-shell ipc call lockScreen lock
bindsym --locked XF86AudioPlay exec qs -c noctalia-shell ipc call media playPause
bindsym --locked XF86AudioPrev exec qs -c noctalia-shell ipc call media previous
bindsym --locked XF86AudioNext exec qs -c noctalia-shell ipc call media next
bindsym --locked XF86AudioRaiseVolume exec qs -c noctalia-shell ipc call volume increase
bindsym --locked XF86AudioLowerVolume exec qs -c noctalia-shell ipc call volume decrease
bindsym --locked XF86AudioMute exec qs -c noctalia-shell ipc call volume muteOutput
bindsym --locked XF86AudioMicMute exec qs -c noctalia-shell ipc call volume muteInput
bindsym --locked XF86MonBrightnessUp exec qs -c noctalia-shell ipc call brightness increase
bindsym --locked XF86MonBrightnessDown exec qs -c noctalia-shell ipc call brightness decrease

# Focus.
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+comma focus parent
bindsym $mod+period focus child

# Move windows.
bindsym $mod+Ctrl+Left move left
bindsym $mod+Ctrl+Down move down
bindsym $mod+Ctrl+Up move up
bindsym $mod+Ctrl+Right move right
bindsym $mod+Ctrl+$left move left
bindsym $mod+Ctrl+$down move down
bindsym $mod+Ctrl+$up move up
bindsym $mod+Ctrl+$right move right

# Outputs / workspaces.
bindsym $mod+Shift+Left focus output left
bindsym $mod+Shift+Down focus output down
bindsym $mod+Shift+Up focus output up
bindsym $mod+Shift+Right focus output right
bindsym $mod+Ctrl+Shift+Left move workspace to output left
bindsym $mod+Ctrl+Shift+Down move workspace to output down
bindsym $mod+Ctrl+Shift+Up move workspace to output up
bindsym $mod+Ctrl+Shift+Right move workspace to output right

# Workspace switching follows positional Vim: u is j/down/next, i is k/up/previous.
bindsym $mod+u workspace next_on_output
bindsym $mod+i workspace prev_on_output
bindsym $mod+Shift+u move container to workspace next_on_output
bindsym $mod+Shift+i move container to workspace prev_on_output
bindsym $mod+Ctrl+u move container to workspace next_on_output
bindsym $mod+Ctrl+i move container to workspace prev_on_output
bindsym $mod+s workspace $ws2
bindsym $mod+Ctrl+s move container to workspace $ws2
bindsym $mod+n workspace $ws3
bindsym $mod+Ctrl+n move container to workspace $ws3
bindsym $mod+a workspace $ws4
bindsym $mod+Ctrl+a move container to workspace $ws4

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9

bindsym $mod+Ctrl+1 move container to workspace $ws1
bindsym $mod+Ctrl+2 move container to workspace $ws2
bindsym $mod+Ctrl+3 move container to workspace $ws3
bindsym $mod+Ctrl+4 move container to workspace $ws4
bindsym $mod+Ctrl+5 move container to workspace $ws5
bindsym $mod+Ctrl+6 move container to workspace $ws6
bindsym $mod+Ctrl+7 move container to workspace $ws7
bindsym $mod+Ctrl+8 move container to workspace $ws8
bindsym $mod+Ctrl+9 move container to workspace $ws9

# Native approximation for Niri pin/stash: scratchpad.
bindsym $mod+p scratchpad show
bindsym $mod+Shift+p move scratchpad
# TODO: no native direct equivalent for summon pinned window / move beside pinned.

# Layout.
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+f fullscreen toggle global
bindsym $mod+m fullscreen toggle
bindsym $mod+z floating toggle
bindsym $mod+Shift+z focus mode_toggle
bindsym $mod+w layout tabbed
bindsym $mod+r mode "resize"

mode "resize" {
    bindsym $left resize shrink width 25px
    bindsym $down resize grow height 25px
    bindsym $up resize shrink height 25px
    bindsym $right resize grow width 25px
    bindsym Left resize shrink width 25px
    bindsym Down resize grow height 25px
    bindsym Up resize shrink height 25px
    bindsym Right resize grow width 25px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

floating_modifier $mod normal

# Keep distro/user drop-ins available.
include /etc/sway/config.d/*
