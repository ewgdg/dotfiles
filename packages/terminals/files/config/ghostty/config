theme = Gruvbox Material Dark

# Window
window-width = 100
window-height = 25
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
background-opacity = 0.9

# Keep wheel input unmultiplied so each layer receives one event per notch.
mouse-scroll-multiplier = precision:1,discrete:1

# Font
font-family = CaskaydiaCove Nerd Font Mono
font-size = 19

# Cursor
cursor-style = block
cursor-style-blink = false
cursor-color = #F1C2A6
cursor-text = #282828
# Vim can still request a bar cursor for insert mode; make that bar three pixels thicker.
adjust-cursor-thickness = 3

# Notify when a long-running command finishes while this terminal is unfocused.
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 5s

# Clipboard
# Match Alacritty's OSC 52 policy: applications may copy, but not read the clipboard.
clipboard-read = deny
clipboard-write = allow

keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard
# Let Herdr receive this chord instead of writing and pasting a terminal screen file.
keybind = ctrl+shift+j=unbind

# Tabs
keybind = ctrl+shift+h=previous_tab
keybind = ctrl+shift+l=next_tab

# Send Shift+Enter using the CSI-u sequence expected by the tmux configuration.
keybind = shift+enter=csi:13;2u
