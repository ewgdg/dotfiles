.DS_Store
/.codex

# Ignore Alfred cache directories
alfred/Alfred.alfredpreferences/workflows/*/[Cc]aches/
alfred/Alfred.alfredpreferences/workflows/*/[Cc]ache/

# Ignore Alfred workflow logs
alfred/Alfred.alfredpreferences/workflows/*/[Ll]ogs/
alfred/Alfred.alfredpreferences/workflows/*/[Ll]og/

# Ignore Python bytecode caches
__pycache__/

# Ignore local Python packaging metadata generated by uv/setuptools
*.egg-info/
