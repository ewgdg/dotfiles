#!/usr/bin/env sh

# Check if the correct number of arguments is provided
if [ "$#" -lt 1 ]; then
    USERNAME="$(logname)"
    echo "User is $USERNAME"
else
    USERNAME=$1
fi

# Input arguments
CONFIG_FILE="/etc/gdm/custom.conf"

enable_auto_login() {
  local username=$1
  
  # Ensure the [daemon] section exists, if not append it to the file
  if ! grep -q "^\[daemon\]" "$CONFIG_FILE"; then
    echo -e "\n[daemon]" >> "$CONFIG_FILE"
  fi

  disable_auto_login
  sed -i "/^\[daemon\]/aAutomaticLoginEnable=True\nAutomaticLogin=$username" "$CONFIG_FILE"
}

disable_auto_login() {
  # Remove the AutomaticLoginEnable and AutomaticLogin under the [daemon] section
  sed -i '/^\[daemon\]/,/^\[/ {
    /AutomaticLoginEnable/d
    /AutomaticLogin/d
  }' "$CONFIG_FILE"
}

# List all sessions
sessions=$(loginctl list-sessions --no-legend | awk '{print $1}')

for session in $sessions; do
  # Get details for each session
  user=$(loginctl show-session "$session" -p Name --value)
  seat=$(loginctl show-session "$session" -p Seat --value)

  # Check if the session belongs to the user and has a seat
  if [ "$user" = "$USERNAME" ] && [ -n "$seat" ]; then
    echo "Session $session for user $USERNAME has a seat: $seat"
    # Unlock the session
    loginctl unlock-session "$session"
    echo "Session $session unlocked."
    
    # Terminate the script early
    exit 0
  fi
done

# If the script reaches here, no session was found
echo "No session found for user $USERNAME with a seat."
echo "Logging in."

enable_auto_login $USERNAME && sudo systemctl restart gdm && disable_auto_login

echo "Logged in."
