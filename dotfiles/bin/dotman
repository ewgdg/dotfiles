#!/usr/bin/env bash
set -euo pipefail

expand_home_path() {
  local raw_path="$1"
  case "$raw_path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${raw_path#~/}"
      ;;
    *)
      printf '%s\n' "$raw_path"
      ;;
  esac
}

resolve_config_path() {
  local args=("$@")
  local idx=0
  local arg=""

  while (( idx < ${#args[@]} )); do
    arg="${args[$idx]}"
    case "$arg" in
      -c|--cfg)
        if (( idx + 1 < ${#args[@]} )); then
          expand_home_path "${args[$((idx + 1))]}"
          return
        fi
        ;;
      --cfg=*)
        expand_home_path "${arg#--cfg=}"
        return
        ;;
    esac
    idx=$((idx + 1))
  done

  if [[ -n "${DOTDROP_CONFIG:-}" ]]; then
    expand_home_path "$DOTDROP_CONFIG"
    return
  fi

  if [[ -f "${PWD}/config.yaml" ]]; then
    printf '%s\n' "${PWD}/config.yaml"
    return
  fi

  if [[ -f "${PWD}/config.toml" ]]; then
    printf '%s\n' "${PWD}/config.toml"
    return
  fi

  printf '%s\n' ""
}

if (( $# == 0 )); then
  exec dotdrop
fi

case "$1" in
  update|install|import|default)
    ;;
  *)
    exec dotdrop "$@"
    ;;
esac

config_path="$(resolve_config_path "$@")"
if [[ -z "$config_path" ]]; then
  echo "unable to determine dotdrop config path; pass -c/--cfg or set DOTDROP_CONFIG" >&2
  exit 2
fi

repo_root="$(cd -- "$(dirname -- "$config_path")" && pwd)"
script_path="${repo_root}/scripts/dotman.py"
repo_core_env_path="${repo_root}/dotfiles/env.core.sh"

if [[ -r "$repo_core_env_path" ]]; then
  # shellcheck source=/dev/null
  . "$repo_core_env_path"
fi

if [[ "$1" != "default" ]] && ! command -v dotdrop >/dev/null 2>&1; then
  echo "dotdrop not found in PATH" >&2
  exit 127
fi

if [[ ! -r "$script_path" ]]; then
  installed_script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  bundled_script_path="$(cd -- "${installed_script_dir}/../.." && pwd)/scripts/dotman.py"
  if [[ -r "$bundled_script_path" ]]; then
    script_path="$bundled_script_path"
  else
    echo "dotman helper not found at ${script_path}" >&2
    exit 2
  fi
fi

exec uv run --project "$repo_root" "$script_path" "$@"
