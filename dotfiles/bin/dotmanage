#!/usr/bin/env bash
set -euo pipefail

if ! command -v dotdrop >/dev/null 2>&1; then
  echo "dotdrop not found in PATH" >&2
  exit 127
fi

dotdrop_cmd="$(command -v dotdrop)"
operation="update"

if (( $# > 0 )); then
  case "$1" in
    update|install|import)
      operation="$1"
      shift
      ;;
    -*)
      ;;
    *)
      echo "unsupported command '$1'; expected 'update', 'install', or 'import'" >&2
      exit 2
      ;;
  esac
fi

command_args=("$@")

if [[ "$operation" == "import" ]]; then
  "$dotdrop_cmd" "$operation" -b "${command_args[@]}"
  exit $?
fi

base_args=()
files_args=()
explicit_targets=()
key_mode=false
force_mode=false
profile_from_args=""
update_ignore_patterns=()
effective_profile=""
config_path_from_args=""
resolved_config_path=""
repo_root=""
template_update_script=""

expand_home_path() {
  local raw_path="$1"
  case "$raw_path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${raw_path#~/}"
      ;;
    *)
      printf '%s\n' "$raw_path"
      ;;
  esac
}

make_absolute_path() {
  local expanded_path=""

  expanded_path="$(expand_home_path "$1")"
  case "$expanded_path" in
    /*)
      printf '%s\n' "$expanded_path"
      ;;
    *)
      printf '%s\n' "${PWD}/${expanded_path}"
      ;;
  esac
}

normalize_target_path() {
  local absolute_path=""
  local python_cmd=""

  absolute_path="$(make_absolute_path "$1")"
  if command -v realpath >/dev/null 2>&1; then
    realpath -m -- "$absolute_path"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
  elif command -v python >/dev/null 2>&1; then
    python_cmd="python"
  else
    printf '%s\n' "$absolute_path"
    return
  fi

  "$python_cmd" -c 'import os, sys; print(os.path.realpath(os.path.abspath(sys.argv[1])))' "$absolute_path"
}

matches_ignore_pattern() {
  local path="$1"
  local pattern="$2"
  local subpath="$path"

  while true; do
    if [[ "$subpath" == $pattern ]]; then
      return 0
    fi

    if [[ "$subpath" == "/" ]]; then
      break
    fi

    subpath="$(dirname "$subpath")"
  done

  return 1
}

path_is_ignored() {
  local path="$1"
  shift
  local -a all_patterns=("$@")
  local -a neg_patterns=()
  local positive_match_count=0
  local pattern=""

  for pattern in "${all_patterns[@]}"; do
    if [[ "$pattern" == "!"* ]]; then
      neg_patterns+=("${pattern#!}")
      continue
    fi

    if matches_ignore_pattern "$path" "$pattern"; then
      positive_match_count=$((positive_match_count + 1))
    fi
  done

  if (( positive_match_count < 1 )); then
    return 1
  fi

  for pattern in "${neg_patterns[@]}"; do
    if matches_ignore_pattern "$path" "$pattern" && (( positive_match_count > 0 )); then
      positive_match_count=$((positive_match_count - 1))
    fi
  done

  if (( positive_match_count < 1 )); then
    return 1
  fi

  if (( ${#neg_patterns[@]} > 0 )) && { [[ -d "$path" ]] || [[ ! -e "$path" ]]; }; then
    return 1
  fi

  return 0
}

key_is_fully_ignored_for_update() {
  local key_dst="$1"
  local key_src="$2"
  local -a raw_patterns=("${@:3}")
  local -a prefixes=("$key_dst")
  local -a absolute_patterns=()
  local raw_pattern=""
  local pattern=""
  local prefix=""
  local is_negative=false

  if [[ -n "$key_src" ]]; then
    prefixes+=("$key_src")
  fi

  for raw_pattern in "${raw_patterns[@]}"; do
    pattern="$raw_pattern"
    is_negative=false
    if [[ "$pattern" == "!"* ]]; then
      is_negative=true
      pattern="${pattern#!}"
    fi

    if [[ "$pattern" == /* ]]; then
      :
    elif [[ "$pattern" == *"*"* && ( "$pattern" == "*"* || "$pattern" == /* ) ]]; then
      :
    else
      for prefix in "${prefixes[@]}"; do
        if [[ "$is_negative" == true ]]; then
          absolute_patterns+=("!${prefix}/${pattern}")
        else
          absolute_patterns+=("${prefix}/${pattern}")
        fi
      done
      continue
    fi

    if [[ "$is_negative" == true ]]; then
      absolute_patterns+=("!$pattern")
    else
      absolute_patterns+=("$pattern")
    fi
  done

  if path_is_ignored "$key_dst" "${absolute_patterns[@]}"; then
    return 0
  fi

  if [[ -n "$key_src" ]] && path_is_ignored "$key_src" "${absolute_patterns[@]}"; then
    return 0
  fi

  return 1
}

resolve_effective_profile() {
  local files_output_human=""

  if [[ -n "$profile_from_args" ]]; then
    printf '%s\n' "$profile_from_args"
    return
  fi

  files_output_human="$("$dotdrop_cmd" files -b "${files_args[@]}" 2>/dev/null || true)"
  while IFS= read -r profile_line; do
    case "$profile_line" in
      'Dotfile(s) for profile "'*'":')
        profile_line="${profile_line#Dotfile(s) for profile \"}"
        profile_line="${profile_line%\":}"
        printf '%s\n' "$profile_line"
        return
        ;;
    esac
  done <<< "$files_output_human"
}

resolve_config_path() {
  if [[ -n "$config_path_from_args" ]]; then
    make_absolute_path "$config_path_from_args"
    return
  fi

  if [[ -n "${DOTDROP_CONFIG:-}" ]]; then
    make_absolute_path "$DOTDROP_CONFIG"
    return
  fi

  if [[ -f "${PWD}/config.yaml" ]]; then
    printf '%s\n' "${PWD}/config.yaml"
    return
  fi

  if [[ -f "${PWD}/config.toml" ]]; then
    printf '%s\n' "${PWD}/config.toml"
    return
  fi

  printf '%s\n' ""
}

# Parse args for execution, key discovery, and explicit targets.
args=("${command_args[@]}")
arg_count=${#args[@]}
after_double_dash=false
for ((idx = 0; idx < arg_count; idx++)); do
  arg="${args[$idx]}"

  if [[ "$after_double_dash" == true ]]; then
    explicit_targets+=("$arg")
    continue
  fi

  case "$arg" in
    --)
      after_double_dash=true
      ;;
    -k|--key)
      if [[ "$operation" == "update" ]]; then
        key_mode=true
      else
        base_args+=("$arg")
      fi
      ;;
    -f|--force)
      force_mode=true
      base_args+=("$arg")
      ;;
    -c|--cfg|-p|--profile)
      if (( idx + 1 >= arg_count )); then
        echo "missing value for $arg" >&2
        exit 2
      fi
      value="${args[$((idx + 1))]}"
      if [[ "$arg" == "-p" || "$arg" == "--profile" ]]; then
        profile_from_args="$value"
      elif [[ "$arg" == "-c" || "$arg" == "--cfg" ]]; then
        config_path_from_args="$value"
      fi
      base_args+=("$arg" "$value")
      files_args+=("$arg" "$value")
      idx=$((idx + 1))
      ;;
    --cfg=*|--profile=*)
      if [[ "$arg" == --profile=* ]]; then
        profile_from_args="${arg#--profile=}"
      elif [[ "$arg" == --cfg=* ]]; then
        config_path_from_args="${arg#--cfg=}"
      fi
      base_args+=("$arg")
      files_args+=("$arg")
      ;;
    -V|--verbose|-b|--no-banner)
      base_args+=("$arg")
      files_args+=("$arg")
      ;;
    -w|--workers)
      if (( idx + 1 >= arg_count )); then
        echo "missing value for $arg" >&2
        exit 2
      fi
      base_args+=("$arg" "${args[$((idx + 1))]}")
      idx=$((idx + 1))
      ;;
    -i|--ignore)
      if (( idx + 1 >= arg_count )); then
        echo "missing value for $arg" >&2
        exit 2
      fi
      value="${args[$((idx + 1))]}"
      update_ignore_patterns+=("$value")
      base_args+=("$arg" "$value")
      idx=$((idx + 1))
      ;;
    --workers=*)
      base_args+=("$arg")
      ;;
    --ignore=*)
      update_ignore_patterns+=("${arg#--ignore=}")
      base_args+=("$arg")
      ;;
    -*)
      if [[ "$arg" == --force || ( "$arg" != --* && "$arg" == *f* ) ]]; then
        force_mode=true
      fi
      base_args+=("$arg")
      ;;
    *)
      explicit_targets+=("$arg")
      ;;
  esac
done

resolved_config_path="$(resolve_config_path)"
if [[ -z "$resolved_config_path" ]]; then
  echo "unable to determine dotdrop config path; pass -c/--cfg or set DOTDROP_CONFIG" >&2
  exit 2
fi

repo_root="$(dirname -- "$resolved_config_path")"
template_update_script="${repo_root}/scripts/dotdrop_template_update.py"

dotfiles_output="$("$dotdrop_cmd" files -G "${files_args[@]}")"
effective_profile="$(resolve_effective_profile)"

all_keys=()
all_dsts=()
declare -A source_by_key=()
declare -A destination_by_key=()
declare -A normalized_destination_by_key=()
declare -A effective_template_by_key=()
while IFS= read -r line; do
  [[ "$line" == *,dst:* ]] || continue
  key="${line%%,*}"
  dst_part="${line#*,dst:}"
  dst="${dst_part%%,*}"
  src=""
  if [[ "$line" == *,src:* ]]; then
    src_part="${line#*,src:}"
    src="${src_part%%,*}"
  fi
  all_keys+=("$key")
  all_dsts+=("$dst")
  source_by_key["$key"]="$src"
  destination_by_key["$key"]="$dst"
  normalized_destination_by_key["$key"]="$(normalize_target_path "$dst")"
done <<< "$dotfiles_output"

if [[ "$operation" == "update" ]]; then
  if [[ -z "$effective_profile" ]]; then
    echo "unable to determine active dotdrop profile" >&2
    exit 2
  fi

  detail_output="$("$dotdrop_cmd" detail -b "${files_args[@]}" "${all_keys[@]}")"
  detail_key=""
  while IFS= read -r detail_line; do
    if [[ "$detail_line" =~ ^([^[:space:]]+)\ \(dst:\ \" ]]; then
      detail_key="${BASH_REMATCH[1]}"
      effective_template_by_key["$detail_key"]=0
      continue
    fi

    if [[ -n "$detail_key" && "$detail_line" == *"(template:yes)"* ]]; then
      effective_template_by_key["$detail_key"]=1
    fi
  done <<< "$detail_output"
fi

install_keys=()
regular_update_paths=()
template_update_keys=()
declare -A regular_update_key_by_path=()
declare -A regular_update_scope_by_path=()
declined_update_backup_dir=""
declare -a declined_update_backup_paths=()
declare -a declined_update_source_paths=()

record_regular_update_path() {
  local target_path="$1"
  local target_key="${2:-}"
  local target_scope="${3:-}"
  local normalized_path=""
  local normalized_scope=""
  local existing_scopes=""

  normalized_path="$(normalize_target_path "$target_path")"
  if [[ -z "${regular_update_key_by_path[$normalized_path]+x}" ]]; then
    regular_update_paths+=("$normalized_path")
  fi

  if [[ -n "$target_key" ]]; then
    regular_update_key_by_path["$normalized_path"]="$target_key"
  fi

  if [[ -z "$target_scope" ]]; then
    return
  fi

  normalized_scope="$(normalize_target_path "$target_scope")"
  existing_scopes="${regular_update_scope_by_path[$normalized_path]:-}"

  case $'\n'"$existing_scopes"$'\n' in
    *$'\n'"$normalized_scope"$'\n'*)
      ;;
    *)
      if [[ -n "$existing_scopes" ]]; then
        existing_scopes+=$'\n'
      fi
      existing_scopes+="$normalized_scope"
      regular_update_scope_by_path["$normalized_path"]="$existing_scopes"
      ;;
  esac
}

record_template_update_key() {
  local target_key="$1"
  template_update_keys+=("$target_key")
}

append_split_key() {
  local split_key="$1"
  local split_dst="$2"
  local split_src="$3"

  if [[ "$operation" == "update" && ${#update_ignore_patterns[@]} -gt 0 ]]; then
    if key_is_fully_ignored_for_update "$split_dst" "$split_src" "${update_ignore_patterns[@]}"; then
      return
    fi
  fi

  if [[ "$operation" == "update" ]]; then
    if [[ "${effective_template_by_key[$split_key]:-0}" == "1" ]]; then
      record_template_update_key "$split_key"
    else
      record_regular_update_path "$split_dst" "$split_key"
    fi
    return
  fi

  install_keys+=("$split_key")
}

find_matching_update_key_for_path() {
  local requested_path="$1"
  local known_key=""
  local known_destination=""
  local matched_key=""
  local matched_length=0

  for known_key in "${all_keys[@]}"; do
    known_destination="${normalized_destination_by_key[$known_key]}"
    if [[ "$requested_path" == "$known_destination" ]]; then
      printf '%s\n' "$known_key"
      return
    fi

    if [[ "$requested_path" == "$known_destination"/* ]]; then
      if (( ${#known_destination} > matched_length )); then
        matched_key="$known_key"
        matched_length=${#known_destination}
      fi
    fi
  done

  printf '%s\n' "$matched_key"
}

if (( ${#explicit_targets[@]} > 0 )); then
  if [[ "$operation" == "update" && "$key_mode" != true ]]; then
    for requested_path in "${explicit_targets[@]}"; do
      normalized_requested_path="$(normalize_target_path "$requested_path")"
      matched_key="$(find_matching_update_key_for_path "$normalized_requested_path")"

      if [[ -n "$matched_key" ]]; then
        if [[ "${effective_template_by_key[$matched_key]:-0}" == "1" ]]; then
          record_template_update_key "$matched_key"
        else
          record_regular_update_path "${destination_by_key[$matched_key]}" "$matched_key" "$normalized_requested_path"
        fi
      else
        record_regular_update_path "$normalized_requested_path"
      fi
    done
  else
    for requested_key in "${explicit_targets[@]}"; do
      if [[ -z "${destination_by_key[$requested_key]+x}" ]]; then
        echo "unknown dotdrop key '$requested_key' for current profile/config" >&2
        exit 2
      fi

      append_split_key "$requested_key" "${destination_by_key[$requested_key]}" "${source_by_key[$requested_key]}"
    done
  fi
else
  for ((key_idx = 0; key_idx < ${#all_keys[@]}; key_idx++)); do
    key_name="${all_keys[$key_idx]}"
    append_split_key "$key_name" "${all_dsts[$key_idx]}" "${source_by_key[$key_name]}"
  done
fi

if (( ${#explicit_targets[@]} == 0 )) && [[ "$force_mode" != true ]]; then
  if [[ -z "$effective_profile" ]]; then
    effective_profile="<unknown>"
  fi

  operation_word="Update"
  if [[ "$operation" == "install" ]]; then
    operation_word="Install"
  fi

  confirmation_prompt="$operation_word all dotfiles for profile \"$effective_profile\" [y/N] ? "

  if [[ -t 0 ]]; then
    read -r -p "$confirmation_prompt" confirmation_answer
  else
    echo "confirmation required but no interactive tty is available; pass explicit targets to skip prompt" >&2
    exit 2
  fi

  case "${confirmation_answer:-}" in
    y|Y|yes|YES)
      ;;
    *)
      echo "aborted" >&2
      exit 1
      ;;
  esac
fi

path_matches_update_scope() {
  local candidate_path="$1"
  local scope_list="$2"
  local scope_path=""

  if [[ -z "$scope_list" ]]; then
    return 0
  fi

  while IFS= read -r scope_path; do
    [[ -n "$scope_path" ]] || continue
    if [[ "$candidate_path" == "$scope_path" || "$candidate_path" == "$scope_path"/* ]]; then
      return 0
    fi
  done <<< "$scope_list"

  return 1
}

collect_update_overwrite_paths() {
  local target_key="$1"
  local source_path="${source_by_key[$target_key]:-}"
  local live_path="${normalized_destination_by_key[$target_key]:-${destination_by_key[$target_key]:-}}"
  local -n overwrite_paths_ref="$2"
  local diff_output=""
  local diff_line=""
  local diff_exit_code=0
  local relative_path=""

  overwrite_paths_ref=()

  if [[ -z "$source_path" || -z "$live_path" ]]; then
    return 1
  fi

  if [[ -d "$source_path" || -d "$live_path" ]]; then
    if [[ ! -d "$source_path" || ! -d "$live_path" ]]; then
      return 1
    fi

    set +e
    diff_output="$(diff -qr --no-dereference "$source_path" "$live_path")"
    diff_exit_code=$?
    set -e

    if (( diff_exit_code == 0 || diff_exit_code > 1 )); then
      return 1
    fi

    while IFS= read -r diff_line; do
      [[ -n "$diff_line" ]] || continue

      case "$diff_line" in
        "Files $source_path/"*" and $live_path/"*" differ")
          relative_path="${diff_line#Files $source_path/}"
          relative_path="${relative_path%% and $live_path/*}"
          overwrite_paths_ref+=("$live_path/$relative_path")
          ;;
      esac
    done <<< "$diff_output"

    if (( ${#overwrite_paths_ref[@]} == 0 )); then
      return 1
    fi

    return 0
  fi

  if [[ ! -f "$source_path" || ! -f "$live_path" ]]; then
    return 1
  fi

  if cmp -s -- "$source_path" "$live_path"; then
    return 1
  fi

  overwrite_paths_ref+=("$live_path")
  return 0
}

ensure_declined_update_backup_dir() {
  if [[ -n "$declined_update_backup_dir" ]]; then
    return
  fi

  declined_update_backup_dir="$(mktemp -d)"
}

backup_declined_update_path() {
  local source_file_path="$1"
  local live_file_path="$2"
  local backup_index="${#declined_update_source_paths[@]}"
  local backup_path=""

  ensure_declined_update_backup_dir
  backup_path="$declined_update_backup_dir/$backup_index"
  cp -p -- "$source_file_path" "$backup_path"
  cp -p -- "$live_file_path" "$source_file_path"
  declined_update_backup_paths+=("$backup_path")
  declined_update_source_paths+=("$source_file_path")
}

restore_declined_update_paths() {
  local restore_idx=""
  local backup_path=""
  local source_file_path=""

  if (( ${#declined_update_source_paths[@]} == 0 )); then
    return
  fi

  for ((restore_idx = 0; restore_idx < ${#declined_update_source_paths[@]}; restore_idx++)); do
    backup_path="${declined_update_backup_paths[$restore_idx]}"
    source_file_path="${declined_update_source_paths[$restore_idx]}"
    cp -p -- "$backup_path" "$source_file_path"
  done
}

cleanup_declined_update_backups() {
  if [[ -n "$declined_update_backup_dir" && -d "$declined_update_backup_dir" ]]; then
    rm -rf -- "$declined_update_backup_dir"
  fi
}

restore_declined_update_state() {
  restore_declined_update_paths
  cleanup_declined_update_backups
}

confirm_update_overwrite_targets() {
  local target_path=""
  local target_key=""
  local target_scopes=""
  local source_root=""
  local live_root=""
  local overwrite_path=""
  local overwrite_relative_path=""
  local source_file_path=""
  local confirmation_answer=""
  local -a overwrite_paths=()

  if [[ "$operation" != "update" || "$force_mode" == true ]]; then
    return
  fi

  if [[ ! -t 0 ]]; then
    return
  fi

  for target_path in "${regular_update_paths[@]}"; do
    target_key="${regular_update_key_by_path[$target_path]:-}"
    target_scopes="${regular_update_scope_by_path[$target_path]:-}"

    if [[ -z "$target_key" ]]; then
      continue
    fi

    if ! collect_update_overwrite_paths "$target_key" overwrite_paths; then
      continue
    fi

    source_root="${source_by_key[$target_key]}"
    live_root="${normalized_destination_by_key[$target_key]:-${destination_by_key[$target_key]}}"

    for overwrite_path in "${overwrite_paths[@]}"; do
      overwrite_relative_path="${overwrite_path#"$live_root"/}"
      if [[ -d "$source_root" ]]; then
        source_file_path="$source_root/$overwrite_relative_path"
      else
        source_file_path="$source_root"
      fi

      if ! path_matches_update_scope "$overwrite_path" "$target_scopes"; then
        backup_declined_update_path "$source_file_path" "$overwrite_path"
        continue
      fi

      printf 'overwrite dotfiles file "%s" [y/N] ? ' "$source_file_path"
      read -r confirmation_answer
      case "${confirmation_answer:-}" in
        y|Y|yes|YES)
          ;;
        *)
          backup_declined_update_path "$source_file_path" "$overwrite_path"
          ;;
      esac
    done
  done
}

print_phase_header() {
  local header_text="$1"

  if [[ -t 1 && -z "${NO_COLOR:-}" && "${TERM:-}" != "dumb" ]]; then
    printf '\n\033[1;34m==>\033[0m \033[1m%s\033[0m\n\n' "$header_text"
    return
  fi

  printf '\n==> %s\n\n' "$header_text"
}

build_compare_focus_args() {
  local operation_targets=("$@")
  local focus_target=""
  local compare_path=""
  local -a compare_focus_args=()

  for focus_target in "${operation_targets[@]}"; do
    if [[ -n "${normalized_destination_by_key[$focus_target]+x}" ]]; then
      compare_path="${normalized_destination_by_key[$focus_target]}"
    else
      compare_path="$focus_target"
    fi
    compare_focus_args+=(-C "$compare_path")
  done

  printf '%s\0' "${compare_focus_args[@]}"
}

path_needs_privileged_read() {
  local target_path="$1"

  if [[ ! -e "$target_path" ]]; then
    return 1
  fi

  if [[ -d "$target_path" ]]; then
    if [[ ! -r "$target_path" || ! -x "$target_path" ]]; then
      return 0
    fi
    return 1
  fi

  if [[ ! -r "$target_path" ]]; then
    return 0
  fi

  return 1
}

path_needs_privileged_write() {
  local target_path="$1"
  local probe_path="$target_path"

  if [[ -e "$probe_path" ]]; then
    if [[ -d "$probe_path" ]]; then
      if [[ ! -w "$probe_path" || ! -x "$probe_path" ]]; then
        return 0
      fi
      return 1
    fi

    if [[ ! -w "$probe_path" ]]; then
      return 0
    fi
    return 1
  fi

  probe_path="$(dirname -- "$probe_path")"
  while [[ ! -e "$probe_path" && "$probe_path" != "/" ]]; do
    probe_path="$(dirname -- "$probe_path")"
  done

  if [[ ! -d "$probe_path" ]]; then
    return 0
  fi

  if [[ ! -w "$probe_path" || ! -x "$probe_path" ]]; then
    return 0
  fi

  return 1
}

system_phase_needs_run() {
  local operation_targets=("$@")
  local compare_output=""
  local compare_exit_code=0
  local compare_line=""
  local -a compare_call=("$dotdrop_cmd" compare -L -b)
  local -a compare_focus_args=()

  if (( ${#operation_targets[@]} == 0 )); then
    return 1
  fi

  compare_call+=("${files_args[@]}")
  while IFS= read -r -d '' compare_arg; do
    compare_focus_args+=("$compare_arg")
  done < <(build_compare_focus_args "${operation_targets[@]}")
  compare_call+=("${compare_focus_args[@]}")

  set +e
  compare_output="$("${compare_call[@]}" 2>&1)"
  compare_exit_code=$?
  set -e

  if (( compare_exit_code != 0 )); then
    return 0
  fi

  while IFS= read -r compare_line; do
    case "$compare_line" in
      ""|' '*)
        continue
        ;;
      *' dotfile(s) compared.')
        continue
        ;;
      *)
        return 0
        ;;
    esac
  done <<< "$compare_output"

  return 1
}

run_operation_for_targets() {
  local run_with_sudo="$1"
  shift
  local operation_targets=("$@")
  local dotdrop_call=("$dotdrop_cmd" "$operation" -b)

  dotdrop_call+=("${base_args[@]}")

  if [[ "$operation" == "install" ]]; then
    dotdrop_call+=("${operation_targets[@]}")
  else
    dotdrop_call+=("${operation_targets[@]}")
  fi

  if [[ "$run_with_sudo" == "true" ]]; then
    if [[ -n "${DOTDROP_CONFIG:-}" ]]; then
      sudo env PATH="$PATH" DOTDROP_CONFIG="$DOTDROP_CONFIG" "${dotdrop_call[@]}"
    else
      sudo env PATH="$PATH" "${dotdrop_call[@]}"
    fi
  else
    "${dotdrop_call[@]}"
  fi

}

print_noop_phase_summary() {
  local processed_count="$1"
  local result_verb=""

  case "$operation" in
    install)
      result_verb="installed"
      ;;
    update)
      result_verb="updated"
      ;;
    *)
      result_verb="$operation"
      ;;
  esac

  printf '%d file(s) processed, 0 %s\n' "$processed_count" "$result_verb"
}

split_paths_by_required_read_privilege() {
  local non_privileged_name="$1"
  local privileged_name="$2"
  shift 2
  local phase_target=""
  local -n non_privileged_targets_ref="$non_privileged_name"
  local -n privileged_targets_ref="$privileged_name"

  non_privileged_targets_ref=()
  privileged_targets_ref=()

  for phase_target in "$@"; do
    if path_needs_privileged_read "$phase_target"; then
      privileged_targets_ref+=("$phase_target")
    else
      non_privileged_targets_ref+=("$phase_target")
    fi
  done
}

split_keys_by_required_read_privilege() {
  local non_privileged_name="$1"
  local privileged_name="$2"
  shift 2
  local target_key=""
  local target_dst=""
  local -n non_privileged_keys_ref="$non_privileged_name"
  local -n privileged_keys_ref="$privileged_name"

  non_privileged_keys_ref=()
  privileged_keys_ref=()

  for target_key in "$@"; do
    target_dst="${normalized_destination_by_key[$target_key]}"
    if path_needs_privileged_read "$target_dst"; then
      privileged_keys_ref+=("$target_key")
    else
      non_privileged_keys_ref+=("$target_key")
    fi
  done
}

split_keys_by_required_write_privilege() {
  local non_privileged_name="$1"
  local privileged_name="$2"
  shift 2
  local target_key=""
  local target_dst=""
  local -n non_privileged_keys_ref="$non_privileged_name"
  local -n privileged_keys_ref="$privileged_name"

  non_privileged_keys_ref=()
  privileged_keys_ref=()

  for target_key in "$@"; do
    target_dst="${normalized_destination_by_key[$target_key]}"
    if path_needs_privileged_write "$target_dst"; then
      privileged_keys_ref+=("$target_key")
    else
      non_privileged_keys_ref+=("$target_key")
    fi
  done
}

overall_exit_code=0
last_template_update_changed=false
run_phase_operation() {
  local phase_name="$1"
  local run_with_sudo="$2"
  shift 2
  local phase_targets=("$@")
  local phase_exit_code=0

  if (( ${#phase_targets[@]} == 0 )); then
    return
  fi

  set +e
  run_operation_for_targets "$run_with_sudo" "${phase_targets[@]}"
  phase_exit_code=$?
  set -e

  if (( phase_exit_code != 0 )); then
    echo "$phase_name phase exited with status $phase_exit_code" >&2
    if (( overall_exit_code == 0 )); then
      overall_exit_code=$phase_exit_code
    fi
  fi
}

run_named_phase() {
  local phase_name="$1"
  local run_with_sudo="$2"
  shift 2
  local phase_targets=("$@")
  local operation_verb=""
  local should_preflight=false

  if (( ${#phase_targets[@]} == 0 )); then
    return
  fi

  case "$operation" in
    install)
      operation_verb="installing"
      ;;
    update)
      operation_verb="updating"
      ;;
    *)
      operation_verb="$operation"
      ;;
  esac

  print_phase_header "$operation_verb $phase_name"

  if [[ "$operation" == "install" && "$run_with_sudo" == "true" ]]; then
    should_preflight=true
  fi

  if [[ "$should_preflight" == "true" ]] && ! system_phase_needs_run "${phase_targets[@]}"; then
    print_noop_phase_summary "${#phase_targets[@]}"
    return
  fi

  run_phase_operation "$phase_name" "$run_with_sudo" "${phase_targets[@]}"
}

run_template_update_for_key() {
  local key_name="$1"
  local target_src="${source_by_key[$key_name]}"
  local target_dst="${normalized_destination_by_key[$key_name]:-${destination_by_key[$key_name]}}"
  local live_input="$target_dst"
  local helper_output=""
  local helper_output_compact=""
  local matched_lines=""
  local whole_blocks=""
  local partial_blocks=""
  local conflict_blocks=""
  local unchanged_blocks=""

  last_template_update_changed=false

  if [[ ! -f "$target_src" ]]; then
    echo "template-aware update only supports file sources; key '$key_name' uses '$target_src'" >&2
    return 2
  fi

  if [[ ! -r "$template_update_script" ]]; then
    echo "template update helper not found at $template_update_script" >&2
    return 2
  fi

  if [[ ! -e "$target_dst" ]]; then
    echo "live destination for key '$key_name' not found at '$target_dst'" >&2
    return 1
  fi

  set +e
  if path_needs_privileged_read "$target_dst"; then
    helper_output="$(
      sudo cat "$target_dst" | uv run "$template_update_script" "$target_src" - --in-place --json
    )"
  else
    helper_output="$(uv run "$template_update_script" "$target_src" "$live_input" --in-place --json)"
  fi
  local update_exit_code=$?
  set -e

  if (( update_exit_code != 0 )); then
    return "$update_exit_code"
  fi

  helper_output_compact="${helper_output//$'\n'/}"

  if [[ "$helper_output_compact" =~ \"changed\":true ]]; then
    last_template_update_changed=true
  elif [[ "$helper_output_compact" =~ \"changed\":false ]]; then
    last_template_update_changed=false
  else
    echo "unexpected template update status for key '$key_name': $helper_output" >&2
    return 2
  fi

  if [[ "$last_template_update_changed" == true ]]; then
    if [[ "$helper_output_compact" =~ \"matched_lines\":([0-9]+) ]]; then
      matched_lines="${BASH_REMATCH[1]}"
    else
      matched_lines="?"
    fi
    if [[ "$helper_output_compact" =~ \"whole_blocks\":([0-9]+) ]]; then
      whole_blocks="${BASH_REMATCH[1]}"
    else
      whole_blocks="?"
    fi
    if [[ "$helper_output_compact" =~ \"partial_blocks\":([0-9]+) ]]; then
      partial_blocks="${BASH_REMATCH[1]}"
    else
      partial_blocks="?"
    fi
    if [[ "$helper_output_compact" =~ \"conflict_blocks\":([0-9]+) ]]; then
      conflict_blocks="${BASH_REMATCH[1]}"
    else
      conflict_blocks="?"
    fi
    if [[ "$helper_output_compact" =~ \"unchanged_blocks\":([0-9]+) ]]; then
      unchanged_blocks="${BASH_REMATCH[1]}"
    else
      unchanged_blocks="?"
    fi
    printf \
      'merged template update: key=%s matched_lines=%s whole_blocks=%s partial_blocks=%s conflict_blocks=%s unchanged_blocks=%s output=%s\n' \
      "$key_name" \
      "$matched_lines" \
      "$whole_blocks" \
      "$partial_blocks" \
      "$conflict_blocks" \
      "$unchanged_blocks" \
      "$target_src"
  fi

  return "$update_exit_code"
}

run_template_phase() {
  local phase_name="$1"
  shift
  local template_keys=("$@")
  local key_name=""
  local phase_exit_code=0
  local operation_verb=""
  local processed_count=0
  local changed_count=0
  local failed_count=0

  if (( ${#template_keys[@]} == 0 )); then
    return
  fi

  case "$operation" in
    install)
      operation_verb="installing"
      ;;
    update)
      operation_verb="updating"
      ;;
    *)
      operation_verb="$operation"
      ;;
  esac

  print_phase_header "$operation_verb $phase_name"

  for key_name in "${template_keys[@]}"; do
    set +e
    run_template_update_for_key "$key_name"
    phase_exit_code=$?
    set -e

    if (( phase_exit_code != 0 )); then
      failed_count=$((failed_count + 1))
      echo "$phase_name template update failed for key '$key_name'" >&2
      if (( overall_exit_code == 0 )); then
        overall_exit_code=$phase_exit_code
      fi
      continue
    fi

    processed_count=$((processed_count + 1))
    if [[ "$last_template_update_changed" == true ]]; then
      changed_count=$((changed_count + 1))
    fi
  done

  if (( failed_count > 0 )); then
    printf '%d file(s) processed, %d updated, %d failed\n' \
      "$processed_count" \
      "$changed_count" \
      "$failed_count"
  else
    printf '%d file(s) processed, %d updated\n' \
      "$processed_count" \
      "$changed_count"
  fi
}

if [[ "$operation" != "update" ]]; then
  declare -a non_privileged_install_keys=()
  declare -a privileged_install_keys=()

  split_keys_by_required_write_privilege \
    non_privileged_install_keys \
    privileged_install_keys \
    "${install_keys[@]}"

  run_named_phase "dotfiles" false "${non_privileged_install_keys[@]}"
  run_named_phase "dotfiles (sudo)" true "${privileged_install_keys[@]}"
  exit "$overall_exit_code"
fi

if [[ "$operation" == "update" ]]; then
  trap restore_declined_update_state EXIT
  confirm_update_overwrite_targets
fi

declare -a non_privileged_update_paths=()
declare -a privileged_update_paths=()
declare -a non_privileged_template_keys=()
declare -a privileged_template_keys=()

split_paths_by_required_read_privilege \
  non_privileged_update_paths \
  privileged_update_paths \
  "${regular_update_paths[@]}"
split_keys_by_required_read_privilege \
  non_privileged_template_keys \
  privileged_template_keys \
  "${template_update_keys[@]}"

run_named_phase "dotfiles" false "${non_privileged_update_paths[@]}"
run_named_phase "dotfiles (sudo)" true "${privileged_update_paths[@]}"
run_template_phase "dotfiles (template-aware)" "${non_privileged_template_keys[@]}"
run_template_phase "dotfiles (template-aware, sudo)" "${privileged_template_keys[@]}"

exit "$overall_exit_code"
