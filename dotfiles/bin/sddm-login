#!/usr/bin/env sh

# Check if the script is run as root
if [ "$EUID" -ne 0 ]; then
  echo "This script requires root privileges. Re-running with sudo..."
  exec sudo -E "$0" "$@"
fi

# exit immediately if any command fails
set -e

# Default session type
SESSION_TYPE="x11"

# Parse command line arguments
while [ "$#" -gt 0 ]; do
    case "$1" in
        -w|--wayland)
            SESSION_TYPE="wayland"
            shift
            ;;
        -x|--x11)
            SESSION_TYPE="x11"
            shift
            ;;
        -h|--help)
            echo "Usage: $0 [OPTIONS] [USERNAME]"
            echo "Options:"
            echo "  -w, --wayland    Use Wayland session"
            echo "  -x, --x11        Use X11 session (default)"
            echo "  -h, --help       Show this help message"
            exit 0
            ;;
        *)
            USER_NAME="$1"
            shift
            ;;
    esac
done

# Set default username if not provided
if [ -z "$USER_NAME" ]; then
    USER_NAME="$(logname)"
    echo "User is $USER_NAME"
else
    echo "User is $USER_NAME"
fi

# Input arguments
CONFIG_FILE="/etc/sddm.conf"

# Set session based on session type
if [ "$SESSION_TYPE" = "wayland" ]; then
    SESSION="plasma"
    echo "Using Wayland session"
else
    SESSION="plasmax11"
    echo "Using X11 session"
fi

assert_result() {
    if [ $? -ne 0 ]; then
        exit 1
    fi
}

create_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    if [ ! -f "$CONFIG_FILE" ]; then
        touch "$CONFIG_FILE"
    fi
    assert_result
}

enable_auto_login() {
    # Ensure the [Autologin] section exists, if not append it to the file
    if ! grep -q "^\[Autologin\]" "$CONFIG_FILE"; then
        echo -e "\n[Autologin]" >> "$CONFIG_FILE"
    fi

    disable_auto_login
    sed -i "/^\[Autologin\]/aUser=$USER_NAME\nSession=$SESSION" "$CONFIG_FILE"

    assert_result
}

disable_auto_login() {
    sed -i '/^\[Autologin\]/,/^\[/ {
        /User/d
        /Session/d
    }' "$CONFIG_FILE"
    assert_result
}

# find the session with a seat
find_session() {
    local sessions=$(loginctl list-sessions --no-legend | awk '{print $1}')
    for session in $sessions; do
        # Get details for each session
        user=$(loginctl show-session "$session" -p Name --value)
        seat=$(loginctl show-session "$session" -p Seat --value)

        # Check if the session belongs to the user and has a seat
        if [ "$user" = "$USER_NAME" ] && [ -n "$seat" ]; then
            echo $session
            return
        fi
    done
}

session=$(find_session)
if [ -n "$session" ]; then
    echo "Session $session for user $USER_NAME has a seat: $seat"
    # Unlock the session
    loginctl unlock-session "$session"
    # move mouse to wake up the monitor
    ydotool mousemove -x 1 -y 0
    ydotool mousemove -x -1 -y 0
    echo "Session $session unlocked."
    # Terminate the script early
    exit 0
fi
assert_result
# If the script reaches here, no session was found
echo "No session found for user $USER_NAME with a seat."
echo "Logging in."

create_config
enable_auto_login $USER_NAME && systemctl restart sddm 

# wait until login
while true; do
    session=$(find_session)
    if [ -n "$session" ]; then
        break
    fi
    sleep 0.5
done
echo "Logged in."

disable_auto_login
