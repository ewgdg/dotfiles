#!/usr/bin/env sh

set -eu

SCRIPT_NAME=$(basename "$0")
AUTLOGIN_FILE=/etc/sddm.conf.d/zzz-autologin.local.conf
DESKTOP=
DESKTOP_USER=
DESKTOP_HOME=
SUNSHINE_DIR=
SUNSHINE_LINK=

usage() {
    cat <<EOF
Usage: $SCRIPT_NAME [--user USERNAME] <kde|niri|status>

Switch the active desktop by:
  - updating $AUTLOGIN_FILE
  - relinking USER_HOME/.config/sunshine/sunshine.conf

Examples:
  $SCRIPT_NAME kde
  $SCRIPT_NAME niri
  $SCRIPT_NAME status
  $SCRIPT_NAME --user xian kde
EOF
}

parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --user)
                if [ $# -lt 2 ]; then
                    printf 'Missing value for --user\n' >&2
                    usage >&2
                    exit 1
                fi
                DESKTOP_USER=$2
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            kde|niri|status)
                if [ -n "${DESKTOP:-}" ]; then
                    printf 'Unexpected extra argument: %s\n' "$1" >&2
                    usage >&2
                    exit 1
                fi
                DESKTOP=$1
                shift
                ;;
            *)
                printf 'Unsupported argument: %s\n' "$1" >&2
                usage >&2
                exit 1
                ;;
        esac
    done

    if [ -z "${DESKTOP:-}" ]; then
        usage >&2
        exit 1
    fi
}

ensure_root_for_switch() {
    if [ "$DESKTOP" = "status" ] || [ "$(id -u)" -eq 0 ]; then
        return
    fi

    exec sudo "$0" "$@"
}

resolve_desktop_user() {
    if [ -n "${DESKTOP_USER:-}" ]; then
        return
    fi

    if [ -n "${SUDO_USER:-}" ]; then
        DESKTOP_USER=$SUDO_USER
        return
    fi

    DESKTOP_USER=$(id -un)
}

resolve_desktop_home() {
    DESKTOP_HOME=$(getent passwd "$DESKTOP_USER" | cut -d: -f6)
    if [ -z "${DESKTOP_HOME:-}" ]; then
        printf 'Unable to resolve home directory for user: %s\n' "$DESKTOP_USER" >&2
        exit 1
    fi
}

setup_paths() {
    SUNSHINE_DIR=$DESKTOP_HOME/.config/sunshine
    SUNSHINE_LINK=$SUNSHINE_DIR/sunshine.conf
}

desktop_session() {
    case "$1" in
        kde) printf '%s\n' plasma ;;
        niri) printf '%s\n' niri ;;
        *)
            printf 'Unsupported desktop: %s\n' "$1" >&2
            exit 1
            ;;
    esac
}

sunshine_target() {
    printf '%s\n' "$SUNSHINE_DIR/sunshine-$1.conf"
}

print_status() {
    current_session="missing"
    current_target="missing"

    if [ -f "$AUTLOGIN_FILE" ]; then
        current_session=$(sed -n 's/^Session=//p' "$AUTLOGIN_FILE" | tail -n 1)
        [ -n "$current_session" ] || current_session="unset"
    fi

    if [ -L "$SUNSHINE_LINK" ]; then
        current_target=$(readlink "$SUNSHINE_LINK")
    elif [ -e "$SUNSHINE_LINK" ]; then
        current_target="exists but is not a symlink"
    fi

    printf 'Autologin file: %s\n' "$AUTLOGIN_FILE"
    printf 'Target user: %s\n' "$DESKTOP_USER"
    printf 'Autologin session: %s\n' "$current_session"
    printf 'Sunshine config: %s\n' "$current_target"
}

write_autologin() {
    desktop=$1
    session=$(desktop_session "$desktop")
    tmp_file=$(mktemp)
    trap 'rm -f "$tmp_file"' EXIT INT TERM

    cat >"$tmp_file" <<EOF
[Autologin]
User=$DESKTOP_USER
Session=$session
Relogin=false
EOF

    mkdir -p "$(dirname "$AUTLOGIN_FILE")"
    install -m 0644 "$tmp_file" "$AUTLOGIN_FILE"
    rm -f "$tmp_file"
    trap - EXIT INT TERM
}

link_sunshine() {
    desktop=$1
    target=$(sunshine_target "$desktop")

    if [ ! -e "$target" ]; then
        printf 'Missing Sunshine config: %s\n' "$target" >&2
        exit 1
    fi

    mkdir -p "$SUNSHINE_DIR"
    ln -sfn "$target" "$SUNSHINE_LINK"
}

main() {
    parse_args "$@"
    ensure_root_for_switch "$@"
    resolve_desktop_user
    resolve_desktop_home
    setup_paths

    case "$DESKTOP" in
        status)
            print_status
            ;;
        kde|niri)
            write_autologin "$DESKTOP"
            link_sunshine "$DESKTOP"
            printf 'Switched desktop to %s\n' "$DESKTOP"
            print_status
            ;;
        *)
            printf 'Unsupported desktop: %s\n' "$DESKTOP" >&2
            exit 1
            ;;
    esac
}

main "$@"
