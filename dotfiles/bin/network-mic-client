#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: network-mic-client <destination-host-or-ip> [port]

Environment overrides:
  NMC_AUDIO_DEVICE   avfoundation audio device selector (default: :default)
  NMC_PORT           destination UDP port (default: 55041)
  NMC_CODEC          audio codec (default: mp2)
  NMC_BITRATE        audio bitrate (default: 192k)
  NMC_CHANNELS       output channels (default: 2)
  NMC_SAMPLE_RATE    output sample rate (default: 48000)
  NMC_FFMPEG_LOGLEVEL ffmpeg log level (default: warning)

Examples:
  network-mic-client 192.168.1.9
  network-mic-client xian-linux-server.local 55041
  NMC_AUDIO_DEVICE=":2" network-mic-client 192.168.1.9
EOF
}

have_command() {
  command -v "$1" >/dev/null 2>&1
}

is_ipv4_literal() {
  [[ "${1}" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

resolve_ipv4() {
  local host="${1}"
  local resolved_ip=""

  if is_ipv4_literal "${host}"; then
    printf '%s\n' "${host}"
    return 0
  fi

  if have_command dscacheutil; then
    resolved_ip="$(
      dscacheutil -q host -a name "${host}" 2>/dev/null \
        | awk '/^ip_address: / && $2 ~ /^[0-9.]+$/ { print $2; exit }'
    )"
  fi

  if [[ -z "${resolved_ip}" ]] && have_command getent; then
    resolved_ip="$(
      getent ahostsv4 "${host}" 2>/dev/null \
        | awk 'NR == 1 { print $1; exit }'
    )"
  fi

  if [[ -z "${resolved_ip}" ]] && have_command host; then
    resolved_ip="$(
      host -t A "${host}" 2>/dev/null \
        | awk '/has address/ { print $4; exit }'
    )"
  fi

  if [[ -z "${resolved_ip}" ]]; then
    printf 'Could not resolve an IPv4 address for %s\n' "${host}" >&2
    return 1
  fi

  printf '%s\n' "${resolved_ip}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 1
fi

destination_host="${1}"

: "${NMC_AUDIO_DEVICE:=:default}"
: "${NMC_PORT:=55041}"
: "${NMC_CODEC:=mp2}"
: "${NMC_BITRATE:=192k}"
: "${NMC_CHANNELS:=2}"
: "${NMC_SAMPLE_RATE:=48000}"
: "${NMC_FFMPEG_LOGLEVEL:=warning}"

if [[ $# -eq 2 ]]; then
  NMC_PORT="${2}"
fi

destination_ip="$(resolve_ipv4 "${destination_host}")"

printf 'Streaming mic to udp://%s:%s\n' "${destination_ip}" "${NMC_PORT}" >&2

exec ffmpeg \
  -hide_banner \
  -loglevel "${NMC_FFMPEG_LOGLEVEL}" \
  -f avfoundation \
  -i "${NMC_AUDIO_DEVICE}" \
  -ac "${NMC_CHANNELS}" \
  -ar "${NMC_SAMPLE_RATE}" \
  -c:a "${NMC_CODEC}" \
  -b:a "${NMC_BITRATE}" \
  -f mpegts \
  "udp://${destination_ip}:${NMC_PORT}"
