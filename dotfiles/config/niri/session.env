# Session-wide environment for Niri user services.
# This file is imported into the user systemd manager and dbus activation environment
# by `niri-session-setup.service` before `niri.service` starts.

# ELECTRON_OZONE_PLATFORM_HINT=auto
# QT_QPA_PLATFORM=wayland
QT_QPA_PLATFORMTHEME=kde
QS_ICON_THEME=Papirus-Dark

# GTK_IM_MODULE=fcitx
QT_IM_MODULE=fcitx
QT_IM_MODULES='wayland;fcitx;ibus'
XMODIFIERS='@im=fcitx'
SDL_IM_MODULE=fcitx
