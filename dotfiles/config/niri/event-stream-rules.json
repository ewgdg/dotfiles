{
  "rules": [
    {
      "name": "close-floating-goldendict-on-focus-loss",
      "event": "focus-changed",
      "match": {
        "previous": {
          "app_id": {
            "regex": "^(org\\.goldendict\\.GoldenDict|goldendict)$",
            "ignore_case": true
          },
          "is_floating": true
        }
      },
      "action": {
        "type": "close-window",
        "target": "previous"
      }
    }
  ]
}
