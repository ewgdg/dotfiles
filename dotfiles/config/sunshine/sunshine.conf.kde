global_prep_cmd = [{"do":"sh -c \"kscreen-doctor output.DP-1.enable output.DP-1.primary output.DP-1.mode.${SUNSHINE_CLIENT_WIDTH}x${SUNSHINE_CLIENT_HEIGHT}@${SUNSHINE_CLIENT_FPS}\"","undo":"kscreen-doctor output.DP-1.disable"},{"do":"kscreen-doctor output.HDMI-A-1.disable","undo":"kscreen-doctor output.HDMI-A-1.enable"},{"do":"sh -c \"systemd-inhibit --who=sunshine --what=idle --why=sunshine-connection -- sleep infinity &\"","undo":"pkill -f sunshine-connection"}]
address_family = both
