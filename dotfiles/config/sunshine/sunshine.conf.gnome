address_family = both
global_prep_cmd = [{"do":"sh -c \"gdctl set -LpM DP-1 --mode ${SUNSHINE_CLIENT_WIDTH}x${SUNSHINE_CLIENT_HEIGHT}@${SUNSHINE_CLIENT_FPS}.000\"","undo":"gdctl set -LpM HDMI-1"},{"do":"sh -c \"gnome-session-inhibit --inhibit idle --reason sunshine-connection --inhibit-only > /dev/null &\"","undo":"pkill -f sunshine-connection"}]
